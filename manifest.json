{
  "manifest_version": 3,
  "name": "Auto Đánh Giá Giáo viên HUST",
  "version": "1.0.0",
  "description": "Chọn nhanh các lựa chọn 0-1-2-3-4 trên form đánh giá dựa theo text hiển thị.",
  "homepage_url": "https://github.com/phamhungcrab/auto-danh-gia-form",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png"
  },
  "action": {
    "default_title": "Auto Đánh Giá Giáo viên HUST",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}